diff --git a/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/node-exporter/files/textfile-collector.sh b/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/node-exporter/files/textfile-collector.sh
new file mode 100644
