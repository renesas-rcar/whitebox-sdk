+
+# do_configure() nothing
+do_configure[noexec] = "1"
+# do_compile() nothing
+do_compile[noexec] = "1"
+
+do_install() {
+    # service file
+   install -d ${D}/${systemd_unitdir}/system
+   install -m 0644 ${WORKDIR}/${SYSTEMD_SERVICE_FILENAME} ${D}/${systemd_unitdir}/system
+
+   # install execution file
+   install -d ${D}/${USRBINPATH}/${PN}
+   install -m 0755 ${WORKDIR}/${PN}.sh ${D}/${USRBINPATH}/${PN}
+}
+
diff --git a/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/prometheus/files/prometheus.service b/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/prometheus/files/prometheus.service
new file mode 100644
index 0000000..d2c6262
--- /dev/null
+++ b/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/prometheus/files/prometheus.service
@@ -0,0 +1,14 @@
+[Unit]
+Description = Prometheus
+After=local-fs.target
+ConditionPathExists=/usr/bin
+
+[Service]
+ExecStart=/usr/bin/prometheus/prometheus --config.file=/usr/bin/prometheus/prometheus.yml --storage.tsdb.path=/var/prometheus --storage.tsdb.retention.time=6h
+WorkingDirectory=/usr/bin/prometheus
+Restart=no
+Type=simple
+
+[Install]
+WantedBy=multi-user.target
+
diff --git a/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/prometheus/prometheus_git.bbappend b/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/prometheus/prometheus_git.bbappend
new file mode 100644
index 0000000..43dee63
--- /dev/null
+++ b/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/prometheus/prometheus_git.bbappend
@@ -0,0 +1,16 @@
+FILESEXTRAPATHS_prepend := "${THISDIR}/files:"
+
+CONF_FILE = "${D}/${USRBINPATH}/${PN}/prometheus.yml"
+do_install_append() {
+    # Change default config
+    sed -i "s/node/S4 node/" ${CONF_FILE}
+    sed -i "s/scrape_interval: 1s/scrape_interval: 5s/" ${CONF_FILE}
+
+    # Additional node
+    echo '  - job_name: "H3 node"' >> ${CONF_FILE}
+    echo '    scrape_interval: 5s' >> ${CONF_FILE}
+    echo '    static_configs:' >> ${CONF_FILE}
+    echo '    - targets: ["192.168.1.111:9100"]' >> ${CONF_FILE}
+    echo '' >> ${CONF_FILE}
+}
+
