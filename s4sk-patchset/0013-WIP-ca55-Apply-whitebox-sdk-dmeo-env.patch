/btn_proc('Attack', \"off\");\r\n  };\r\n  _ws.onclose = function () {\r\n    console.log(\"Close\")\r\n    //clearInterval(timerId)\r\n    //timerId = -1;\r\n    setTimeout(stop, 0); // stop superInterval\r\n    g_sendingFlag = 0;\r\n    if(getBtnState() == \"ON\") send_fakedata()\r\n    //btn_proc('Attack', \"off\");\r\n  };\r\n}\r\nfunction stop_fakedata(){\r\n  //clearInterval(timerId)\r\n  g_sendingFlag = 0;\r\n  _ws.close();\r\n}\r\n\r\nvar send_loop_flg = 0;\r\nfunction send_loop() {\r\n  if ( send_loop_flg != 0)\r\n    return;\r\n  send_loop_flg = 1;\r\n  var t = document.getElementById(\"Attack\");\r\n  if ( t.value == \"OFF\") _ws.close();\r\n  \r\n  var date = new Date();\r\n  base_json['arg']['timestamp'] = date.getTime();\r\n  _json_data = JSON.stringify(base_json);\r\n\r\n  if(g_sendingFlag == 0) {\r\n    _ws.close()\r\n    send_loop_flg = 0;\r\n    return;\r\n  }\r\n  \r\n  var _id = setInterval( () => {\r\n    console.log(\"Timeout !!\")\r\n    _ws.close();\r\n  }, 100);\r\n\r\n  if(_ws.readyState == 1) {\r\n    console.log(\"hello\", _ws.bufferedAmount)\r\n    //console.log(_ws.readyState);\r\n    //console.log(_json_data)\r\n    if (_ws.bufferedAmount == 0)\r\n      _ws.send(_json_data);\r\n    //clearTimeout(timeoutId);\r\n    //timerId = setTimeout(send_loop, 50) // 50msec\r\n    //timerId = superInterval(send_loop, 50);//\r\n  } else {\r\n    //console.log(_ws.readyState);\r\n    _ws.close();\r\n  }\r\n  clearInterval(_id);\r\n  send_loop_flg = 0;\r\n}\r\n\r\n/**\r\n * Call S4 API functions\r\n */\r\nfunction get_req(url){\r\n  var _hostname = window.location.hostname;\r\n  if (_hostname !== \"localhost\") {\r\n    console.log(\"Get: \" + url);\r\n    return;\r\n  } else {\r\n    fetch(url, {\r\n      method: \"GET\"\r\n    })\r\n      .then((response) => response.text())\r\n      .then((text) => {});\r\n  }\r\n}\r\nfunction get_req_v2(url){\r\n  var xhr = new XMLHttpRequest();\r\n  xhr.open(\"GET\", url);\r\n  xhr.send();\r\n  xhr.onload = ()=>