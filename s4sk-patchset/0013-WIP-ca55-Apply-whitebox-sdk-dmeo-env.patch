+[Unit]
+Description=Monitoring vissv2server process
+After=network.target waii.target
+
+[Service]
+Type=simple
+ExecStart=/usr/bin/monitoring-vissv2server.sh
+Restart=on-failure
+
+[Install]
+WantedBy=multi-user.target
+
diff --git a/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/waii/files/monitoring-vissv2server.sh b/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/waii/files/monitoring-vissv2server.sh
new file mode 100644
index 0000000..832dfae
--- /dev/null
+++ b/application_cpu/meta-whitebox-demo/recipes-demo-gen4-domd/waii/files/monitoring-vissv2server.sh
@@ -0,0 +1,14 @@
+#!/bin/bash
+
+while :; do
+    timeout 2 wget -O- localhost:8888 > /dev/null
+    if [[ $? -ne 0 ]]; then
+        echo Error
+        systemctl restart vissv2server
+    else
+        echo OK
+    fi
+    sleep 1
+done
+
+
