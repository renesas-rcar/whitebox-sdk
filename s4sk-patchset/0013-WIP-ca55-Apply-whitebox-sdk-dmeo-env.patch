+ 
+         output = cv_img
+         if GRAYSCALE:
+@@ -129,6 +124,10 @@ class VNCServer(http.server.SimpleHTTPRequestHandler):
+             prev_fps = counter
+             counter = 1
+         prev_sec=sec
++        # Node-exporter
++        with open('/var/textfile_collector/fps.prom.tmp', 'w') as f:
